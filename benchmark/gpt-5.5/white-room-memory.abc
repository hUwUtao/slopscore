V:PnoRH clef=treble name="Piano Right Hand"
%slot=lead %role=catchy_childlike_hook %register=mid_high %dyn=p %art=legato
%doubling=celesta_fragments %blend=keyboard+celesta %rhythm_group=anchor %polyrhythm_group=A
%reason=States the new memorable opening hook and later loop return; the contour has a clear leap-and-neighbor identity while staying sparse.
V:PnoLH clef=bass name="Piano Left Hand"
%slot=ostinato %role=soft_waltz_arpeggio %register=mid_low %dyn=p %art=legato_pedal
%doubling=harp_later %blend=piano+harp %rhythm_group=anchor %polyrhythm_group=A
