V:Harp clef=treble name="Harp"
%slot=pad %role=arpeggiated_harmony %register=wide %dyn=pp %art=rolled_legato
%doubling=piano_left_hand %blend=harp+keyboard %rhythm_group=anchor %polyrhythm_group=A
