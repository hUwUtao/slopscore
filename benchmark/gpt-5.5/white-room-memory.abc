V:VlnI clef=treble name="Violin I"
%slot=lead %role=greatest_muted_string_solo %register=high %dyn=p %art=legato_muted_espressivo
%doubling=flute_after_phrase %blend=small_strings+woodwind %rhythm_group=anchor %polyrhythm_group=A
%reason=Carries the expanded solo arc with one clear apex and stepwise recovery, becoming the emotional core before retreating.
V:VlnII clef=treble name="Violin II"
