V:Cel clef=treble name="Celesta"
%slot=color %role=hook_halo_and_neck_fragments %register=high %dyn=pp %art=detached_legato
%doubling=piano_and_flute_fragments %blend=keyboard_color %rhythm_group=color %polyrhythm_group=A
